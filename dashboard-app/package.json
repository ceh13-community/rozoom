{
  "version": "0.21.0-rc.2",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:rozoom": "VITE_ENABLE_WORKSPACE_DEBUG_PANEL=true VITE_ENABLE_RUNTIME_FILE_LOGS=true VITE_ENABLE_DEVTOOLS_CONSOLE=true VITE_ENABLE_PODS_STREAM_WATCH=true vite dev",
    "build": "vite build",
    "build:staging": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && prettier -c . && eslint && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "tauri:dev:rozoom": "VITE_ENABLE_WORKSPACE_DEBUG_PANEL=true VITE_ENABLE_RUNTIME_FILE_LOGS=true VITE_ENABLE_DEVTOOLS_CONSOLE=true VITE_ENABLE_PODS_STREAM_WATCH=true tauri dev",
    "tauri:info": "tauri info",
    "qa:fixtures:apply": "kubectl apply -f ./qa/fixtures/live-workloads.yaml",
    "qa:live:pods": "node ./qa/live/workloads-smoke.mjs --pods-only",
    "qa:live:workloads": "node ./qa/live/workloads-smoke.mjs",
    "qa:live:configuration": "node ./qa/live/configuration-smoke.mjs",
    "qa:live:network": "node ./qa/live/network-smoke.mjs",
    "qa:live:storage": "node ./qa/live/storage-smoke.mjs",
    "qa:live:custom-resources": "node ./qa/live/custom-resources-smoke.mjs",
    "qa:live:cluster-ops": "node ./qa/live/cluster-ops-smoke.mjs",
    "qa:live:nodes-status": "node ./qa/live/nodes-status-smoke.mjs",
    "qa:live:security-observability": "node ./qa/live/security-observability-smoke.mjs",
    "qa:live:observability-tail": "node ./qa/live/observability-tail-smoke.mjs",
    "qa:live:access-reviews-port-forwarding": "node ./qa/live/access-reviews-port-forwarding-smoke.mjs",
    "qa:live:workbench-parity": "node ./qa/live/workbench-parity.mjs",
    "build:deb": "pnpm exec tauri build --bundles deb && bash ./scripts/normalize-linux-artifact-names.sh",
    "build:rpm": "bash ./scripts/build-linux-rpm.sh && bash ./scripts/normalize-linux-artifact-names.sh",
    "build:linux": "pnpm run build:deb && pnpm run build:rpm",
    "download:binaries": "node ./download-binaries.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:visual": "playwright test visual-regression",
    "test:e2e:journeys": "playwright test critical-user-journeys",
    "test:e2e:update-snapshots": "playwright test visual-regression --update-snapshots",
    "prepare": "cd .. && husky dashboard-app/.husky"
  },
  "lint-staged": {
    "*.{js,ts,css,md,json}": "prettier --write",
    "*.svelte": "prettier --write --plugin prettier-plugin-svelte",
    "*.{js,ts,svelte}": "eslint --fix"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@kubernetes/client-node": "^1.1.2",
    "@lezer/highlight": "^1.2.3",
    "@sentry/sveltekit": "9",
    "@tanstack/table-core": "^8.21.3",
    "@tauri-apps/api": "~2.9.1",
    "@tauri-apps/plugin-dialog": "~2.6.0",
    "@tauri-apps/plugin-fs": "~2",
    "@tauri-apps/plugin-http": "~2",
    "@tauri-apps/plugin-log": "~2.8.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "~2.3.0",
    "@tauri-apps/plugin-shell": "~2.3.1",
    "@tauri-apps/plugin-store": "~2.4.2",
    "@tauri-apps/plugin-window-state": "~2.4.1",
    "ansi_up": "^6.0.6",
    "codemirror": "^6.0.2",
    "extract-zip": "^2.0.1",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "tauri-plugin-cache-api": "^0.1.5",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@lucide/svelte": "^0.482.0",
    "@playwright/test": "^1.56.1",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "~2.9.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.2.9",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.17",
    "@vitest/coverage-v8": "^4.0.17",
    "autoprefixer": "^10.4.21",
    "bits-ui": "^1.8.0",
    "clsx": "^2.1.1",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^27.3.0",
    "lint-staged": "^16.4.0",
    "mode-watcher": "1.1.0",
    "postcss": "^8.5.3",
    "prettier": "3.6.2",
    "prettier-plugin-svelte": "^3.5.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-eslint-parser": "^1.5.1",
    "svelte-sonner": "^0.3.25",
    "tailwind-merge": "^3.2.0",
    "tailwind-variants": "^0.2.1",
    "tailwindcss": "3",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.42.0",
    "vite": "^6.0.3",
    "vite-plugin-devtools-json": "^0.1.0",
    "vitest": "^4.0.15"
  }
}
