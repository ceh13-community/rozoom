# ── Sentry (optional) ─────────────────────────────────────────────
# Browser/server SDK DSN. Leave empty to disable Sentry.
# In dev mode, also set PUBLIC_SENTRY_ENABLE_IN_DEV=true.
# In CI/Docker, pass via --build-arg or GitHub Secrets.
# PUBLIC_SENTRY_DSN=
# PUBLIC_SENTRY_ENVIRONMENT=production
# PUBLIC_SENTRY_ENABLE_IN_DEV=false
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ── Debug panels & tracing ────────────────────────────────────────
# All disabled by default for production. Enable for local debugging.
#
# WARNING: enabling all verbose traces at once floods the main thread
# and can freeze the UI. Enable only what you need, one at a time.
#
# VITE_ENABLE_WORKSPACE_DEBUG_PANEL=false
# VITE_ENABLE_RUNTIME_FILE_LOGS=false
# VITE_ENABLE_VERBOSE_RUNTIME_LOGS=false
# VITE_ENABLE_OVERVIEW_TRACE=false
# VITE_ENABLE_WATCHERS_TRACE=false
# VITE_ENABLE_KUBECTL_TRACE=false
# VITE_ENABLE_BACKGROUND_POLLERS_TRACE=false
# VITE_ENABLE_PODS_STREAM_WATCH=false

# ── Performance ───────────────────────────────────────────────────
# Max parallel kubectl commands. Default: 6 (from dashboard data profile).
# VITE_KUBECTL_MAX_PARALLEL=6

# ── Synthetic fleet (testing) ─────────────────────────────────────
# Enable synthetic fleet harness for stress testing (50-100 fake clusters).
# VITE_ENABLE_SYNTHETIC_FLEET_HARNESS=false

# ── Tool selection (build-time) ───────────────────────────────────
# Comma-separated list of tools to bundle. Unset = all 14 tools enabled.
# Disabled tools are not downloaded, not shown in UI, not probed.
# VITE_ROZOOM_TOOLS=kubectl,helm,kustomize,kubeconform,pluto,stern,velero,yq,aws,gcloud,doctl,hcloud,oc,az

# ── Binary version pins (download-binaries.js) ───────────────────
# Uncomment to pin a specific version. Default: latest from GitHub.
# KUBECTL_VERSION=v1.35.3
# HELM_VERSION=v4.1.3
# DOCTL_VERSION=v1.153.0
# GCLOUD_VERSION=552.0.0
# PLUTO_VERSION=v5.23.5
# VELERO_VERSION=v1.18.0
# KUSTOMIZE_VERSION=v5.8.1
# KUBECONFORM_VERSION=v0.7.0
# STERN_VERSION=v1.33.1
# YQ_VERSION=v4.52.4
# HCLOUD_VERSION=v1.62.0
# OC_VERSION=4.21.0-okd-scos.9
# AZ_VERSION=2.84.0
# AWS_VERSION=2.34.15
